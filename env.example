# Paymob API Keys (Required)
PAYMOB_API_KEY=your_paymob_api_key_here

# Egypt Integration (EGP) - Get these from Paymob Dashboard
PAYMOB_INTEGRATION_ID_EGP=your_integration_id_for_egp_here
PAYMOB_IFRAME_ID_EGP=your_iframe_id_for_egp_here

# USD Integration (Optional - for international payments)
PAYMOB_INTEGRATION_ID_USD=your_integration_id_for_usd_here
PAYMOB_IFRAME_ID_USD=your_iframe_id_for_usd_here

# Legacy/Alternative Environment Variable Names (supported for backwards compatibility)
# PAZMOB_API_KEY (note: typo - PAZMOB instead of PAYMOB)
# PAZMOB_INTEGRATION_ID_EGP
# PAZMOB_IFRAME_ID_EGP

# Server Configuration
PORT=8080

# Admin Auth (Required in production)
ADMIN_USER=admin
# Option A: plain password (server will hash it)
ADMIN_PASSWORD=change-this-password
# Option B: SHA256 hash (preferred in production)
# ADMIN_PASS_HASH=put_sha256_hash_here

# CORS (comma-separated list, no spaces)
# Example: CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
